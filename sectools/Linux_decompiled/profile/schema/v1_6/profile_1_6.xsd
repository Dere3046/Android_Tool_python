    <simpleType name="four_char_hex">
        <restriction base="string">
            <pattern value="0x0*[0-9a-fA-F]{1,4}"/>
        </restriction>
    </simpleType>

    <simpleType name="seven_char_hex">
        <restriction base="string">
            <pattern value="0x0*[0-9a-fA-F]{1,7}"/>
        </restriction>
    </simpleType>

    <simpleType name="eight_char_hex">
        <restriction base="string">
            <pattern value="0x0*[0-9a-fA-F]{1,8}"/>
        </restriction>
    </simpleType>

